          "greet",
          "Hello"
        ]
      },
      {
        "prompt": "What is the function name?",
        "contains_all": [
          "greet"
        ]
      },
      {
        "prompt": "Does the function return Hello?",
        "contains_any": [
          "yes",
          "Yes"
        ]
      }
    ]
  }
}
